# ─── Brand Roadmap — environment variables ────────────────────────────────
# Copy this file to .env.local for local dev. In Railway, set these via the
# project's Variables UI (Settings → Variables).

# ─── Postgres ─────────────────────────────────────────────────────────────
# Railway auto-injects DATABASE_URL when you link a Postgres service to this
# app's service in the same project. For local dev pointing at Railway's
# external connection, use the connection string from the Postgres service's
# "Connect" tab.
#
# After provisioning Postgres, paste the contents of migrations/001_init.sql
# into Railway's Postgres "Data → Query" tab to create the two tables.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ─── Anthropic ────────────────────────────────────────────────────────────
# Same account as toolkit is fine. Split for budget isolation if you want.
ANTHROPIC_API_KEY=sk-ant-...

# ─── ActiveCampaign ───────────────────────────────────────────────────────
# Same account as toolkit. Use a new LIST_ID dedicated to Brand Roadmap leads.
# On report completion the app upserts the contact and applies tags the upsell
# automations branch on (auto-created if missing):
#   roadmap-report-completed
#   roadmap-priority-get-clear | roadmap-priority-get-noticed | roadmap-priority-get-paid
#   roadmap-unpaid  (flips to roadmap-paid via the Stripe webhook once wired)
# Plus custom fields for merge-personalized emails: Brand Roadmap Priority,
# Brand Roadmap Start Here, Brand Roadmap Nudge, Brand Roadmap URL, Brand Roadmap Paid.
ACTIVECAMPAIGN_API_KEY=
ACTIVECAMPAIGN_ACCOUNT=
ACTIVECAMPAIGN_LIST_ID=

# ─── Stripe ───────────────────────────────────────────────────────────────
# Powers the $97 full-roadmap unlock. Payments stay dormant until both are set.
#  1. STRIPE_SECRET_KEY: from Stripe Dashboard → Developers → API keys
#     (use sk_test_... while testing, sk_live_... at launch).
#  2. STRIPE_WEBHOOK_SECRET: create a webhook endpoint pointed at
#     https://roadmap.leftrightlabs.com/api/web-audit/stripe-webhook
#     subscribed to the `checkout.session.completed` event, then copy its
#     signing secret (whsec_...). Use a separate endpoint/secret for test vs live.
# The webhook is what flips a report to paid and stops it from expiring; the
# $97 price is created inline at checkout, so no Price ID is required.
#  3. STRIPE_PUBLISHABLE_KEY: the publishable key (pk_test_.../pk_live_...) from
#     the same API keys page. Needed for the embedded on-site checkout; it's
#     returned to the browser at runtime and is safe to expose. Match test/live
#     mode to the secret + webhook secret above.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# ─── OG image fallback (optional) ─────────────────────────────────────────
# The report header shows a preview of the analyzed site's OpenGraph image.
# We fetch it directly first; when a site is behind a bot filter that blocks
# our server, we fall back to microlink.io. The free tier works with no key
# (rate-limited ~50/day). Set this for the higher-volume Pro tier.
MICROLINK_API_KEY=

# ─── Site config ──────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://roadmap.leftrightlabs.com
