# ─── Brand Roadmap — environment variables ────────────────────────────────
# Copy this file to .env.local for local dev. In Railway, set these via the
# project's Variables UI (Settings → Variables).

# ─── Postgres ─────────────────────────────────────────────────────────────
# Railway auto-injects DATABASE_URL when you link a Postgres service to this
# app's service in the same project. For local dev pointing at Railway's
# external connection, use the connection string from the Postgres service's
# "Connect" tab.
#
# After provisioning Postgres, paste the contents of migrations/001_init.sql
# into Railway's Postgres "Data → Query" tab to create the two tables.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ─── Anthropic ────────────────────────────────────────────────────────────
# Same account as toolkit is fine. Split for budget isolation if you want.
ANTHROPIC_API_KEY=sk-ant-...

# ─── ActiveCampaign ───────────────────────────────────────────────────────
# Same account as toolkit. Use a new LIST_ID dedicated to Brand Roadmap leads.
# On report completion the app upserts the contact and applies tags the upsell
# automations branch on (auto-created if missing):
#   roadmap-report-completed
#   roadmap-priority-get-clear | roadmap-priority-get-noticed | roadmap-priority-get-paid
#   roadmap-unpaid  (flips to roadmap-paid via the Stripe webhook once wired)
# Plus custom fields for merge-personalized emails: Brand Roadmap Priority,
# Brand Roadmap Start Here, Brand Roadmap Nudge, Brand Roadmap URL, Brand Roadmap Paid.
ACTIVECAMPAIGN_API_KEY=
ACTIVECAMPAIGN_ACCOUNT=
ACTIVECAMPAIGN_LIST_ID=

# ─── Site config ──────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://roadmap.leftrightlabs.com
